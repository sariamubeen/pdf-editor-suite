# =============================================================================
# Server Configuration
# =============================================================================

# Your server's private IP (REQUIRED - used by Windows clients to connect)
SERVER_IP=172.20.4.58

# Web app port (user-facing: upload, edit, download)
APP_PORT=8080

# ONLYOFFICE Document Server port (editor engine)
ONLYOFFICE_PORT=8443

# JWT secret for ONLYOFFICE (change this to something random)
JWT_SECRET=pdfeditorsuite

# Session secret for user login cookies (change to a random string)
SESSION_SECRET=change-me-in-production

# =============================================================================
# Branding - change these to customize the app name and appearance
# =============================================================================

# App name shown everywhere (web pages, Windows installer, Open with menu)
APP_NAME=SIERA PDF

# Short name used for Windows install directory and registry (no spaces)
APP_SHORTNAME=SieraPDF

# Logo file in server/app/bundle/ (replace the file to use your own logo)
# Recommended: PNG with transparent background, ~500px wide
APP_LOGO=siera-logo.png
