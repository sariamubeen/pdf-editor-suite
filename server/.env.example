# =============================================================================
# PDF Editor Suite — Server Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Admin password for first login (change immediately after first login)
STIRLING_ADMIN_PASSWORD=ChangeMeOnFirstLogin!

# Organization name embedded in auto-generated signing certificates
CERT_ORG_NAME=My Organization

# Port Stirling-PDF listens on (change if 8080 is already in use)
STIRLING_PORT=8080

# Server URL — used in setup summary and client configuration
# Set this to your server's private IP or domain (no trailing slash)
# Examples:
#   SERVER_URL=http://192.168.1.50:8080
#   SERVER_URL=https://pdf.yourdomain.com
SERVER_URL=http://YOUR_SERVER_IP:8080

# Authentication mode:
#   true  = require login (recommended if server is exposed to the internet)
#   false = no login required (recommended for private/LAN-only networks)
REQUIRE_LOGIN=false

# Credentials for client auto-login (only used if REQUIRE_LOGIN=true)
# These are passed to Windows clients so PDFs open without prompting
STIRLING_USERNAME=admin
STIRLING_PASSWORD=ChangeMeOnFirstLogin!
